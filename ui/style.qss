/* XT-Forge Desktop — Qt stylesheet */
QWidget {
    background: #f4f6fb;
    color: #1a0a16;
    font-family: "Inter", "-apple-system", "Segoe UI", sans-serif;
    font-size: 13px;
}

/* Phase 20 — two-column login/setup shell.
   Left: brand-tinted gradient behind the hero image.
   Right: pure white surface hosting the XT-Forge logo + form. */
#loginLeft {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                stop:0 #f8e8f4, stop:1 #e8dcf0);
    border: none;
}
#loginRight {
    background: #ffffff;
    border: none;
}
#loginHero, #loginLogo {
    background: transparent;
    border: none;
}
#headerLogo {
    background: transparent;
    border: none;
    padding-left: 12px;
}

/* Top bar */
#topBar {
    background: #ffffff;
    border-bottom: 1px solid rgba(0,0,0,0.06);
}
#brand {
    font-size: 15px;
    font-weight: 700;
    color: #1a0a16;
}
#hint {
    color: #6b6470;
    font-size: 12px;
}
/* Phase 12.2 — prettified empty-state block on every stage panel. */
#emptyStateIcon {
    font-size: 40px;
    padding: 6px 0;
}
#emptyStateTitle {
    color: #4a4451;
    font-size: 16px;
    font-weight: 600;
    padding: 0 20px;
}
#emptyStateHint {
    color: #8a8391;
    font-size: 12px;
    padding: 0 24px;
}
/* Indeterminate progress bar under the Run button. */
#runProgress {
    max-height: 4px;
    background: transparent;
    border: none;
}
#runProgress::chunk {
    background-color: #681c5c;
    border-radius: 2px;
}
#clientPill {
    background: rgba(104, 28, 92, 0.08);
    color: #681c5c;
    border: 1px solid rgba(104, 28, 92, 0.25);
    border-radius: 12px;
    padding: 3px 10px;
    font-weight: 600;
    margin-right: 6px;
}
#emailPill {
    color: #6b6470;
    padding: 3px 8px;
    margin-right: 12px;
    font-size: 12px;
}
#linkButton {
    background: transparent;
    color: #681c5c;
    border: none;
    text-decoration: underline;
    font-weight: 500;
    padding: 4px 8px;
}
#linkButton:hover {
    color: #9b3a87;
}

/* Sidebar */
#sidebar {
    background: #0d1e34;
    color: #cbd5e1;
    border: none;
    padding: 8px 0;
    outline: 0;
}
#sidebar::item {
    /* Phase 19 — reserved room for a 18px Bootstrap Icon before the label. */
    padding: 10px 14px;
    border: none;
    font-size: 13px;
}
#sidebar {
    icon-size: 18px;
}
#sidebar::item:selected {
    background: rgba(104, 28, 92, 0.25);
    color: #ffffff;
    border-left: 3px solid #9b3a87;
}
#sidebar::item:!enabled {
    color: #64748b;
    font-size: 11px;
    letter-spacing: 0.06em;
    padding-top: 14px;
    padding-bottom: 4px;
}

/* Content stack */
#contentStack {
    background: #f4f6fb;
}

/* Headings */
QLabel#h1 {
    font-size: 20px;
    font-weight: 700;
    color: #1a0a16;
}
QLabel#error {
    color: #b91c1c;
    background: rgba(220, 38, 38, 0.06);
    border: 1px solid rgba(220, 38, 38, 0.25);
    border-radius: 6px;
    padding: 6px 10px;
}

/* Inputs */
QLineEdit, QTextEdit, QPlainTextEdit {
    background: #ffffff;
    border: 1px solid rgba(104, 28, 92, 0.18);
    border-radius: 8px;
    padding: 8px 10px;
    selection-background-color: #9b3a87;
    selection-color: #ffffff;
}
QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border-color: #9b3a87;
}
QTextEdit#codeBlock {
    font-family: "JetBrains Mono", "Menlo", "Consolas", monospace;
    font-size: 12px;
    background: #f8f4f7;
    color: #2e2231;
}
QPlainTextEdit#terminal {
    background: #140d13;
    color: #f8d9f1;
    border: 1px solid rgba(104, 28, 92, 0.35);
}

/* Buttons */
QPushButton {
    background: #ffffff;
    border: 1px solid rgba(104, 28, 92, 0.25);
    border-radius: 8px;
    padding: 7px 14px;
    color: #2e2231;
    font-weight: 500;
}
QPushButton:hover {
    background: rgba(104, 28, 92, 0.04);
}
QPushButton#primary {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #681c5c, stop:1 #9b3a87);
    color: #ffffff;
    border: none;
    font-weight: 600;
}
QPushButton#primary:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #7d2a71, stop:1 #b04c9c);
}
QPushButton#success {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #059669, stop:1 #10b981);
    color: #ffffff;
    border: none;
    font-weight: 600;
}
QPushButton#success:disabled {
    background: #d1d5db;
    color: #6b7280;
}
QPushButton:disabled {
    color: #94a3b8;
    background: #eef2f7;
    border-color: rgba(0,0,0,0.06);
}

/* Table */
QTableWidget {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    gridline-color: rgba(0,0,0,0.04);
}
QHeaderView::section {
    background: #ffffff;
    color: #6b6470;
    border: none;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    padding: 8px 6px;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.04em;
}
QTableWidget::item {
    padding: 6px 4px;
}

/* Stage scroll container */
QScrollArea#stageScroll { background: transparent; border: none; }
QScrollArea#stageScroll > QWidget > QWidget { background: transparent; }

/* Card */
QFrame#card {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
}
QLabel#cardTitle {
    font-size: 12px;
    font-weight: 700;
    color: #6b6470;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 2px;
}

/* Feature panel headings */
QLabel#featureTitle {
    font-size: 18px;
    font-weight: 700;
    color: #1a0a16;
}
QLabel#featureDescription {
    font-size: 13px;
    color: #2e2231;
    line-height: 1.4em;
}

/* Manual-tests / plan card entries */
QLabel#mtTitle {
    font-size: 14px;
    font-weight: 600;
    color: #1a0a16;
}
QLabel#gwtHead {
    font-size: 11px;
    font-weight: 700;
    color: #6b6470;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-top: 4px;
}
QLabel#bulletMarker {
    color: #9b3a87;
    font-weight: 700;
}

/* Chips (id pills) */
QLabel#chip {
    background: rgba(104, 28, 92, 0.08);
    color: #681c5c;
    border: 1px solid rgba(104, 28, 92, 0.2);
    border-radius: 10px;
    padding: 2px 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    font-weight: 600;
    max-height: 20px;
}

/* KV rows */
QLabel#kvKey {
    color: #6b6470;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.04em;
}

/* Badges */
QLabel[objectName^="badge-"] {
    padding: 2px 10px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 700;
    border: 1px solid transparent;
    max-height: 20px;
}
QLabel#badge-smoke {
    background: rgba(22, 163, 74, 0.08);
    color: #059669;
    border-color: rgba(22, 163, 74, 0.30);
}
QLabel#badge-negative {
    background: rgba(220, 38, 38, 0.08);
    color: #b91c1c;
    border-color: rgba(220, 38, 38, 0.30);
}
QLabel#badge-regression {
    background: rgba(217, 119, 6, 0.08);
    color: #b45309;
    border-color: rgba(217, 119, 6, 0.30);
}
QLabel#badge-neutral {
    background: rgba(104, 28, 92, 0.06);
    color: #681c5c;
    border-color: rgba(104, 28, 92, 0.18);
}

/* Plan step table */
QTableWidget#planStepsTable {
    background: #f8fafc;
}
QTableWidget#planStepsTable::item {
    padding: 4px 6px;
}

/* Review artifacts */
QListWidget#artifactList {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 8px;
    padding: 4px 0;
    outline: 0;
    /* Phase 19 — 16px Bootstrap Icon per row (feature / step-def / page-object). */
    icon-size: 16px;
}
QListWidget#artifactList::item {
    padding: 8px 10px;
    color: #1a0a16;
    border-left: 3px solid transparent;
}
QListWidget#artifactList::item:selected {
    background: rgba(104, 28, 92, 0.08);
    color: #1a0a16;
    border-left-color: #9b3a87;
}
QLabel#filePath {
    color: #6b6470;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    background: #f8f4f7;
    border: 1px solid rgba(104, 28, 92, 0.15);
    border-radius: 4px;
    padding: 4px 8px;
}
QPlainTextEdit#codeViewer {
    /* Phase 21 — VS Code Dark+ palette. Highlighter tokens draw on
       top of this dark background via QSyntaxHighlighter in
       ui/highlighters.py. */
    background: #1e1e1e;
    color: #d4d4d4;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    padding: 10px;
    selection-background-color: #264f78;
    selection-color: #ffffff;
}
QLabel#validationError {
    background: rgba(220, 38, 38, 0.08);
    color: #b91c1c;
    border: 1px solid rgba(220, 38, 38, 0.25);
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 12px;
}
QLabel#validationWarning {
    background: rgba(217, 119, 6, 0.08);
    color: #b45309;
    border: 1px solid rgba(217, 119, 6, 0.25);
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 12px;
}
QPlainTextEdit#codeBlock {
    background: #f8f4f7;
    color: #2e2231;
    border: 1px solid rgba(104, 28, 92, 0.15);
    border-radius: 8px;
    padding: 10px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
}
/* Phase-1 model badge shown next to each stage panel's title. */
QLabel#modelBadge {
    background: rgba(52, 211, 153, 0.10);
    color: #047857;
    border: 1px solid rgba(52, 211, 153, 0.40);
    border-radius: 10px;
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 600;
}
